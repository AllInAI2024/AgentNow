# 智现 AgentNow 企业智能体平台 - 环境变量配置
# 复制此文件为 .env 并修改相应配置

# 项目配置
PROJECT_NAME=智现 AgentNow 企业智能体平台
PROJECT_VERSION=0.1.0
API_PREFIX=/api/v1

# 数据库配置
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/agentnow

# JWT配置 (请在生产环境修改为随机字符串)
JWT_SECRET_KEY=change_this_to_a_random_secret_key_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 默认管理员配置
DEFAULT_ADMIN_PHONE=13651165117
DEFAULT_ADMIN_PASSWORD=123456
DEFAULT_ADMIN_USERNAME=系统管理员

# Hermes 智能体服务配置 (可选)
# HERMES_BASE_URL=http://localhost:8080
